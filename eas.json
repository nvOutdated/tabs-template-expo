{
  "cli": {
    "version": ">= 5.9.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {},
      "env": {
        "ANDROID_PACKAGE_NAME": "com.xdd11.tabscomponentapp.dev",
        "IOS_BUNDLE_ID": "com.xdd11.tabscomponentapp.dev",
        "EAS_BUILD_PROFILE": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {},
      "env": {
        "ANDROID_PACKAGE_NAME": "com.xdd11.tabscomponentapp.preview",
        "IOS_BUNDLE_ID": "com.xdd11.tabscomponentapp.preview",
        "EAS_BUILD_PROFILE": "preview"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {},
      "env": {
        "ANDROID_PACKAGE_NAME": "com.xdd11.tabscomponentapp",
        "IOS_BUNDLE_ID": "com.xdd11.tabscomponentapp",
        "EAS_BUILD_PROFILE": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
